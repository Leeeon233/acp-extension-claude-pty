#!/usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "Usage: $0 <binary_path>"
    exit 1
fi

binary_path="$1"

if [[ ! -f "$binary_path" ]]; then
    echo "Error: Binary not found at $binary_path"
    exit 1
fi

echo "Code signing binary at $binary_path"

if [[ -z "${MACOS_CERTIFICATE:-}" || -z "${MACOS_CERTIFICATE_PASSWORD:-}" || -z "${APPLE_NOTARIZATION_KEY:-}" || -z "${APPLE_NOTARIZATION_KEY_ID:-}" || -z "${APPLE_NOTARIZATION_ISSUER_ID:-}" || -z "${MACOS_CODESIGN_IDENTITY:-}" ]]; then
    echo "Error: One or more required variables are missing:"
    echo "  - MACOS_CERTIFICATE"
    echo "  - MACOS_CERTIFICATE_PASSWORD"
    echo "  - APPLE_NOTARIZATION_KEY"
    echo "  - APPLE_NOTARIZATION_KEY_ID"
    echo "  - APPLE_NOTARIZATION_ISSUER_ID"
    echo "  - MACOS_CODESIGN_IDENTITY"
    exit 1
fi

echo "Setting up keychain for code signing..."
security create-keychain -p "$MACOS_CERTIFICATE_PASSWORD" claude-code-cli-acp.keychain || echo ""
security default-keychain -s claude-code-cli-acp.keychain
security unlock-keychain -p "$MACOS_CERTIFICATE_PASSWORD" claude-code-cli-acp.keychain
security set-keychain-settings claude-code-cli-acp.keychain
echo "$MACOS_CERTIFICATE" | base64 --decode > /tmp/claude-code-cli-acp-certificate.p12
security import /tmp/claude-code-cli-acp-certificate.p12 -k claude-code-cli-acp.keychain -P "$MACOS_CERTIFICATE_PASSWORD" -T /usr/bin/codesign
rm /tmp/claude-code-cli-acp-certificate.p12
security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k "$MACOS_CERTIFICATE_PASSWORD" claude-code-cli-acp.keychain

function cleanup() {
    echo "Cleaning up keychain"
    security default-keychain -s login.keychain
    security delete-keychain claude-code-cli-acp.keychain
}

trap cleanup EXIT

echo "Signing binary ${binary_path}"
/usr/bin/codesign --deep --force --timestamp --options runtime --sign "$MACOS_CODESIGN_IDENTITY" "${binary_path}" -v
echo "✓ Successfully signed ${binary_path}"

echo "Notarizing binary with Apple"

# Create temporary zip file for notarization
temp_zip=$(mktemp).zip
zip -q "$temp_zip" "${binary_path}"

# Create temporary file for the API key
notarization_key_file=$(mktemp)
echo "$APPLE_NOTARIZATION_KEY" > "$notarization_key_file"

# Submit for notarization and wait for completion
xcode_bin_dir_path="$(xcode-select -p)/usr/bin"
"${xcode_bin_dir_path}/notarytool" submit --wait \
    --key "$notarization_key_file" \
    --key-id "$APPLE_NOTARIZATION_KEY_ID" \
    --issuer "$APPLE_NOTARIZATION_ISSUER_ID" \
    "$temp_zip"

rm "$notarization_key_file"
rm "$temp_zip"

echo "✓ Successfully notarized ${binary_path}"
