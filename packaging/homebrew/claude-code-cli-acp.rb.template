class ClaudeCodeCliAcp < Formula
  desc "ACP adapter for the real Claude Code CLI"
  homepage "https://github.com/moabualruz/claude-code-cli-acp"
  version "VERSION"
  license "Apache-2.0"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/moabualruz/claude-code-cli-acp/releases/download/v#{version}/claude-code-cli-acp-#{version}-aarch64-apple-darwin.tar.gz"
      sha256 "SHA256_DARWIN_ARM64"
    else
      url "https://github.com/moabualruz/claude-code-cli-acp/releases/download/v#{version}/claude-code-cli-acp-#{version}-x86_64-apple-darwin.tar.gz"
      sha256 "SHA256_DARWIN_X64"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/moabualruz/claude-code-cli-acp/releases/download/v#{version}/claude-code-cli-acp-#{version}-aarch64-unknown-linux-gnu.tar.gz"
      sha256 "SHA256_LINUX_ARM64"
    else
      url "https://github.com/moabualruz/claude-code-cli-acp/releases/download/v#{version}/claude-code-cli-acp-#{version}-x86_64-unknown-linux-gnu.tar.gz"
      sha256 "SHA256_LINUX_X64"
    end
  end

  def install
    bin.install "claude-code-cli-acp"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/claude-code-cli-acp --version")
  end
end
